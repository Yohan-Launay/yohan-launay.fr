---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 border-b border-zinc-800 glass">
      <div
        class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between"
      >
        <a
          href="#"
          class="text-white font-medium tracking-tight text-lg flex items-center gap-2"
        >
          <div
            class="w-6 h-6 bg-white text-zinc-950 rounded flex items-center justify-center font-bold text-xs"
          >
            J
          </div>
          <span class="tracking-tighter">JON.DEV</span>
        </a>
        <div class="flex items-center gap-6 text-sm font-medium">
          <a
            href="#about"
            class="hover:text-white transition-colors hidden md:block">About</a
          >
          <a
            href="#projects"
            class="hover:text-white transition-colors hidden md:block">Work</a
          >
          <a
            href="#dashboard"
            class="text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5 px-3 py-1.5 rounded-md hover:bg-zinc-900 border border-transparent hover:border-zinc-800"
          >
            <iconify-icon icon="solar:lock-keyhole-linear"></iconify-icon>
            Dashboard
          </a>
        </div>
      </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="relative min-h-screen pt-14">
      <!-- Hero Section -->
      <section
        class="max-w-5xl mx-auto px-6 py-32 md:py-48 flex flex-col items-start animate-fade-in"
      >
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-xs font-medium text-zinc-300 mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
            ></span>
          </span>
          Available for new projects
        </div>
        <h1
          class="text-4xl md:text-6xl font-medium text-white tracking-tight leading-[1.1] mb-6"
        >
          Building digital products with <br />
          <span class="text-zinc-500">precision and clarity.</span>
        </h1>
        <p class="text-lg text-zinc-400 max-w-xl leading-relaxed mb-10">
          I am a full-stack developer focused on creating refined web
          experiences. I blend technical expertise with a keen eye for design to
          build scalable software.
        </p>
        <div class="flex items-center gap-4">
          <button
            class="bg-white text-zinc-950 hover:bg-zinc-200 px-5 py-2.5 rounded-md text-sm font-medium transition-colors"
          >
            View Projects
          </button>
          <button
            class="px-5 py-2.5 rounded-md text-sm font-medium text-zinc-300 hover:text-white border border-zinc-800 hover:bg-zinc-900 transition-all"
          >
            Contact Me
          </button>
        </div>
      </section>

      <!-- Skills / Tech Stack Section -->
      <section id="about" class="border-y border-zinc-900 bg-zinc-900/20">
        <div class="max-w-5xl mx-auto px-6 py-12">
          <p
            class="text-xs font-medium text-zinc-500 uppercase tracking-widest mb-6"
          >
            Technologies
          </p>
          <div
            class="flex flex-wrap gap-x-8 gap-y-4 items-center opacity-70 grayscale hover:grayscale-0 transition-all duration-500"
          >
            <iconify-icon icon="logos:react" width="24"></iconify-icon>
            <iconify-icon icon="logos:nextjs-icon" width="24"></iconify-icon>
            <iconify-icon icon="logos:tailwindcss-icon" width="24"
            ></iconify-icon>
            <iconify-icon icon="logos:typescript-icon" width="24"
            ></iconify-icon>
            <iconify-icon icon="logos:nodejs-icon" width="24"></iconify-icon>
            <iconify-icon icon="logos:postgresql" width="24"></iconify-icon>
            <iconify-icon icon="logos:aws" width="30"></iconify-icon>
            <iconify-icon icon="logos:figma" width="18"></iconify-icon>
          </div>
        </div>
      </section>

      <!-- Projects Section -->
      <section id="projects" class="max-w-5xl mx-auto px-6 py-24">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-2xl font-medium text-white tracking-tight">
            Selected Projects
          </h2>
          <a
            href="#"
            class="text-sm text-zinc-500 hover:text-white transition-colors"
            >View all -></a
          >
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Project Card 1 -->
          <div
            class="group border border-zinc-800 bg-zinc-900/30 rounded-xl overflow-hidden hover:border-zinc-600 transition-all duration-300"
          >
            <div
              class="h-48 bg-zinc-900 border-b border-zinc-800 flex items-center justify-center relative overflow-hidden"
            >
              <div
                class="absolute inset-0 bg-gradient-to-tr from-zinc-900 via-zinc-800 to-zinc-900 opacity-50 group-hover:scale-105 transition-transform duration-500"
              >
              </div>
              <iconify-icon
                icon="solar:chart-square-linear"
                class="text-zinc-700 group-hover:text-white transition-colors text-6xl relative z-10"
              ></iconify-icon>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-medium text-white mb-2">
                Finance API Integration
              </h3>
              <p class="text-sm text-zinc-400 mb-4 line-clamp-2">
                A high-performance microservice architecture handling real-time
                financial data processing and visualization.
              </p>
              <div class="flex items-center justify-between">
                <div class="flex gap-2">
                  <span
                    class="text-xs px-2 py-1 bg-zinc-800 rounded text-zinc-300"
                    >Go</span
                  >
                  <span
                    class="text-xs px-2 py-1 bg-zinc-800 rounded text-zinc-300"
                    >gRPC</span
                  >
                </div>
                <div class="flex gap-3">
                  <a href="#" class="text-zinc-500 hover:text-white"
                    ><iconify-icon icon="solar:github-circle-linear" width="20"
                    ></iconify-icon></a
                  >
                  <a href="#" class="text-zinc-500 hover:text-white"
                    ><iconify-icon icon="solar:link-circle-linear" width="20"
                    ></iconify-icon></a
                  >
                </div>
              </div>
            </div>
          </div>

          <!-- Project Card 2 -->
          <div
            class="group border border-zinc-800 bg-zinc-900/30 rounded-xl overflow-hidden hover:border-zinc-600 transition-all duration-300"
          >
            <div
              class="h-48 bg-zinc-900 border-b border-zinc-800 flex items-center justify-center relative overflow-hidden"
            >
              <div
                class="absolute inset-0 bg-gradient-to-tr from-zinc-900 via-zinc-800 to-zinc-900 opacity-50 group-hover:scale-105 transition-transform duration-500"
              >
              </div>
              <iconify-icon
                icon="solar:cart-large-minimalistic-linear"
                class="text-zinc-700 group-hover:text-white transition-colors text-6xl relative z-10"
              ></iconify-icon>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-medium text-white mb-2">
                E-Commerce Headless CMS
              </h3>
              <p class="text-sm text-zinc-400 mb-4 line-clamp-2">
                Custom shopfront built with Next.js 14 utilizing a headless CMS
                backend for maximum flexibility and speed.
              </p>
              <div class="flex items-center justify-between">
                <div class="flex gap-2">
                  <span
                    class="text-xs px-2 py-1 bg-zinc-800 rounded text-zinc-300"
                    >Next.js</span
                  >
                  <span
                    class="text-xs px-2 py-1 bg-zinc-800 rounded text-zinc-300"
                    >Stripe</span
                  >
                </div>
                <div class="flex gap-3">
                  <a href="#" class="text-zinc-500 hover:text-white"
                    ><iconify-icon icon="solar:github-circle-linear" width="20"
                    ></iconify-icon></a
                  >
                  <a href="#" class="text-zinc-500 hover:text-white"
                    ><iconify-icon icon="solar:link-circle-linear" width="20"
                    ></iconify-icon></a
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Experience Section -->
      <section class="max-w-2xl mx-auto px-6 py-12 mb-24">
        <h2 class="text-xl font-medium text-white tracking-tight mb-8">
          Experience
        </h2>
        <div class="space-y-8 border-l border-zinc-800 pl-8 relative">
          <div class="relative">
            <div
              class="absolute -left-[37px] top-1 h-4 w-4 rounded-full border-2 border-zinc-800 bg-zinc-950"
            >
            </div>
            <div
              class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-1"
            >
              <h4 class="text-white font-medium">Senior Engineer</h4>
              <span class="text-xs text-zinc-500 font-mono">2021 — Present</span
              >
            </div>
            <p class="text-sm text-zinc-400">TechCorp Inc.</p>
            <p class="text-sm text-zinc-500 mt-2">
              Leading the frontend infrastructure team, migrating legacy systems
              to modern React architecture.
            </p>
          </div>
          <div class="relative">
            <div
              class="absolute -left-[37px] top-1 h-4 w-4 rounded-full border-2 border-zinc-800 bg-zinc-950"
            >
            </div>
            <div
              class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-1"
            >
              <h4 class="text-white font-medium">Full Stack Developer</h4>
              <span class="text-xs text-zinc-500 font-mono">2018 — 2021</span>
            </div>
            <p class="text-sm text-zinc-400">Creative Agency</p>
            <p class="text-sm text-zinc-500 mt-2">
              Developed award-winning marketing sites and internal tools using
              Node.js and Vue.
            </p>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="border-t border-zinc-900 py-8 px-6 text-center">
        <p class="text-xs text-zinc-600">
          © 2026 Yohan LAUNAY. Crafted with precision.
        </p>
      </footer>
    </main>
</Layout>
